{
  "extends": ["taro/react"],
  "rules": {
    "react/jsx-uses-react": "off",
    "react/react-in-jsx-scope": "off",
    "jsx-quotes": ["error", "prefer-double"],
    "import/no-named-as-default": "off"
  },
  "overrides": [
    {
      "files": ["tests/**/*.{ts,tsx}"],
      "rules": {
        "import/first": "off"
      }
    }
  ]
}
