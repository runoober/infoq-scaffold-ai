    "@vueuse/core": "13.9.0",
    "animate.css": "4.1.1",
    "await-to-js": "3.0.0",
    "axios": "1.13.6",
    "crypto-js": "4.2.0",
    "echarts": "5.6.0",
    "element-plus": "2.11.9",
    "file-saver": "2.0.5",
    "highlight.js": "11.11.1",
