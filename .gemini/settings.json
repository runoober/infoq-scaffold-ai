{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "openai-docs": {
      "url": "https://developers.openai.com/mcp"
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "mysql": {
      "command": "bash",
      "args": [
        ".codex/scripts/start_mysql_mcp.sh"
      ],
      "env": {
        "MYSQL_READONLY": "true"
      }
    },
    "redis": {
      "command": "bash",
      "args": [
        ".codex/scripts/start_redis_mcp.sh"
      ],
      "env": {
        "REDIS_READONLY": "true"
      }
    }
  }
}
