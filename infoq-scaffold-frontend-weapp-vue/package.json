{
  "name": "infoq-scaffold-frontend-weapp-vue",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "description": "InfoQ Vue mobile scaffold based on uni-app",
  "scripts": {
    "dev:h5": "uni -p h5 --mode development",
    "dev:weapp": "uni -p mp-weixin --mode development",
    "build:h5": "uni build -p h5",
    "build:weapp": "uni build -p mp-weixin",
    "build:weapp:dev": "NODE_ENV=development uni build -p mp-weixin --mode development",
    "build-open:weapp": "node ../script/build-open-wechat-devtools.mjs --workspace infoq-scaffold-frontend-weapp-vue --framework vue",
    "build-open:weapp:dev": "node ../script/build-open-wechat-devtools.mjs --workspace infoq-scaffold-frontend-weapp-vue --framework vue --mode development",
    "test": "vitest --run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest --run --coverage --config vitest.config.ts",
    "test:e2e:weapp": "pnpm run test:e2e:weapp:smoke",
    "test:e2e:weapp:smoke": "node ./tests/e2e/weapp/runner.mjs --suite smoke",
    "test:e2e:weapp:core": "WEAPP_E2E_AUTO_LOGIN=false node ./tests/e2e/weapp/runner.mjs --suite core",
    "test:e2e:weapp:core:backend": "node ./tests/e2e/weapp/runner.mjs --suite core",
    "test:e2e:weapp:full": "node ./tests/e2e/weapp/runner.mjs --suite full --report",
    "verify:local": "pnpm run test && pnpm run build:weapp:dev && pnpm run test:e2e:weapp:core && pnpm run build:weapp"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-5000620260331001",
    "@dcloudio/uni-app-harmony": "3.0.0-5000620260331001",
    "@dcloudio/uni-app-plus": "3.0.0-5000620260331001",
    "@dcloudio/uni-components": "3.0.0-5000620260331001",
    "@dcloudio/uni-h5": "3.0.0-5000620260331001",
    "@dcloudio/uni-mp-alipay": "3.0.0-5000620260331001",
    "@dcloudio/uni-mp-baidu": "3.0.0-5000620260331001",
    "@dcloudio/uni-mp-harmony": "3.0.0-5000620260331001",
    "@dcloudio/uni-mp-jd": "3.0.0-5000620260331001",
    "@dcloudio/uni-mp-kuaishou": "3.0.0-5000620260331001",
    "@dcloudio/uni-mp-lark": "3.0.0-5000620260331001",
    "@dcloudio/uni-mp-qq": "3.0.0-5000620260331001",
    "@dcloudio/uni-mp-toutiao": "3.0.0-5000620260331001",
    "@dcloudio/uni-mp-weixin": "3.0.0-5000620260331001",
    "@dcloudio/uni-mp-xhs": "3.0.0-5000620260331001",
    "@dcloudio/uni-quickapp-webview": "3.0.0-5000620260331001",
    "aes-js": "^3.1.2",
    "jsencrypt": "^3.5.4",
    "pinia": "2.1.7",
    "vue": "3.4.21"
  },
  "devDependencies": {
    "@dcloudio/types": "3.4.28",
    "@dcloudio/uni-automator": "3.0.0-5000620260331001",
    "@dcloudio/uni-cli-shared": "3.0.0-5000620260331001",
    "@dcloudio/uni-stacktracey": "3.0.0-5000620260331001",
    "@dcloudio/vite-plugin-uni": "3.0.0-5000620260331001",
    "@mini-types/alipay": "^3.0.14",
    "@uni-helper/plugin-uni": "0.1.0",
    "@uni-helper/unh": "^0.3.1",
    "@uni-helper/uni-types": "^1.0.0-alpha.8",
    "@vitest/coverage-v8": "0.34.6",
    "@vue/runtime-core": "3.4.21",
    "@vue/test-utils": "2.4.6",
    "jsdom": "22.1.0",
    "miniprogram-api-typings": "^5.1.2",
    "miniprogram-automator": "0.12.1",
    "sass": "1.64.2",
    "typescript": "5.4.5",
    "vite": "5.2.8",
    "vitest": "0.34.6"
  },
  "pnpm": {
    "patchedDependencies": {
      "jsencrypt@3.5.4": "patches/jsencrypt@3.5.4.patch",
      "miniprogram-automator@0.12.1": "patches/miniprogram-automator@0.12.1.patch"
    }
  }
}
